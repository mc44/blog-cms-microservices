# Blog-cms 0-deploy/.env — AUTH_JWT_SECRET must match auth-service:
# https://github.com/mc44/auth-service/blob/main/deploy/.env.example
#
# Quote values that contain spaces or apostrophes (required for deploy.sh to source this file).

AUTH_SERVICE_URL=http://auth-service:8081
AUTH_JWT_SECRET=change-me-in-env-please-change-me-in-env
BLOG_TENANT_ID=blog-cms
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# Browser origins allowed by gateway CORS (comma-separated, no trailing slashes).
# Match how users open the UI; for same-host nginx, use the same host as NEXT_PUBLIC_GATEWAY_URL.
GATEWAY_CORS_ORIGINS=http://localhost:3000,https://blog.mfajardo.com

# Host ports published on the server (left side of HOST:CONTAINER in compose).
# check-ports.sh reads these — change here first, then redeploy.
MONGO_HOST_PORT=27018
REDIS_HOST_PORT=6380
GATEWAY_HOST_PORT=8080
BLOG_HOST_PORT=8082
MEDIA_HOST_PORT=8083
AUDIT_HOST_PORT=8084
FRONTEND_HOST_PORT=3000
# Container port Next.js listens on (right side in compose; match 3-frontend/Dockerfile ENV PORT)
FRONTEND_CONTAINER_PORT=3000

# Branding — used when DEPLOY_BUILD=true locally. Published frontend images read
# NEXT_PUBLIC_* from GitHub Actions variable FRONTEND_BUILD_ENV (see 3-frontend/.env.production.example).
NEXT_PUBLIC_SITE_NAME=blog
NEXT_PUBLIC_SITE_BYLINE="by mfajardo"
NEXT_PUBLIC_SITE_TAGLINE="Essays on software, productivity, psychology, building, and whatever I'm learning."
NEXT_PUBLIC_HOME_TOPICS=Software,Productivity,Psychology,Building,Habits
NEXT_PUBLIC_AUTHOR_LABEL="Marc Fajardo"
NEXT_PUBLIC_MFAJARDO_URL=https://mfajardo.com
NEXT_PUBLIC_WEEKLY_URL=https://weekly.mfajardo.com
NEXT_PUBLIC_FOCUS_URL=https://focus.mfajardo.com

# Container images — deploy.sh pulls by default (VPS). Set DEPLOY_BUILD=true to build from source locally.
# Run `docker login` on the server before first pull if images are private.
DEPLOY_BUILD=false

# Image repository (without tag). Docker Hub example:
GATEWAY_IMAGE=marcfajardo44/gateway-service
BLOG_IMAGE=marcfajardo44/blog-service
MEDIA_IMAGE=marcfajardo44/media-service
AUDIT_IMAGE=marcfajardo44/audit-service
FRONTEND_IMAGE=marcfajardo44/blog-cms-frontend

# GHCR alternative (uncomment and set owner):
# GITHUB_REPOSITORY_OWNER=mc44
# GATEWAY_IMAGE=ghcr.io/mc44/gateway-service
# BLOG_IMAGE=ghcr.io/mc44/blog-service
# MEDIA_IMAGE=ghcr.io/mc44/media-service
# AUDIT_IMAGE=ghcr.io/mc44/audit-service
# FRONTEND_IMAGE=ghcr.io/mc44/blog-cms-frontend

GATEWAY_IMAGE_TAG=latest
BLOG_IMAGE_TAG=latest
MEDIA_IMAGE_TAG=latest
AUDIT_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# Cloudinary (production uploads). Leave empty for in-memory dev fallback in media-service.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AUDIT_ENABLED=true
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
