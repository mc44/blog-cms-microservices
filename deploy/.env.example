# Blog-cms deploy/.env — auth secrets must match ../auth-service/deploy/.env

AUTH_SERVICE_URL=http://auth-service:8081
AUTH_JWT_SECRET=change-me-in-env-please-change-me-in-env
BLOG_TENANT_ID=blog-cms
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# Branding — replace for your fork (examples below are mfajardo defaults)
NEXT_PUBLIC_SITE_NAME=blog
NEXT_PUBLIC_SITE_BYLINE=by mfajardo
NEXT_PUBLIC_SITE_TAGLINE=Essays on software, productivity, psychology, building, and whatever I'm learning.
NEXT_PUBLIC_HOME_TOPICS=Software,Productivity,Psychology,Building,Habits
NEXT_PUBLIC_AUTHOR_LABEL=Marc Fajardo
NEXT_PUBLIC_MFAJARDO_URL=https://mfajardo.com
NEXT_PUBLIC_WEEKLY_URL=https://weekly.mfajardo.com
NEXT_PUBLIC_FOCUS_URL=https://focus.mfajardo.com

GATEWAY_IMAGE_TAG=latest
BLOG_IMAGE_TAG=latest
MEDIA_IMAGE_TAG=latest
AUDIT_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# Cloudinary (production uploads). Leave empty for in-memory dev fallback in media-service.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AUDIT_ENABLED=true
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
